# mansour — environment template
# Copy to .env and adjust only what you need to change.
# Defaults below are SAFE FOR LOCAL DEVELOPMENT.

# ── Application ───────────────────────────────────────────────
RUST_LOG=info

# Project admin templates live under ./templates; main.rs defaults this to
# "templates" so the overrides load on `cargo run` from this directory.
RUSTIO_TEMPLATE_DIR=templates

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres            # IMPORTANT: change in production
DB_NAME=systemkraft_dev

# rustio-admin reads DATABASE_URL directly; the parts above are substituted
# at .env load time.
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Security ──────────────────────────────────────────────────
# CSRF, session cookies and password hashing are managed by the framework.
# A 32-byte URL-safe-base64 key is only required once a user enables MFA:
#   openssl rand 32 | base64 | tr '+/' '-_' | tr -d '='
RUSTIO_SECRET_KEY=

# ── Initial Admin Account ─────────────────────────────────────
# Admin users are created via the CLI, not env vars:
#   rustio-admin user create --email you@mansour.dev --role administrator
